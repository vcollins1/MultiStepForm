@using System.ComponentModel.DataAnnotations
<DisplayHeader Title="Personal Info" Description="Please provide your name, email address, and phone number."/>
<div class="personal-info">
    <EditForm id="personal-info-form" class="personal-info__data" Model="@_personalInfoModel" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="personal-info__input">
            <label>
                Name:
                <ValidationMessage For="@(() => _personalInfoModel.Name)" />
            </label>
            <InputText class="personal-info__text-input" @bind-Value="@_personalInfoModel.Name" placeholder="e.g. Stephen King"/>
        </div>

        <div class="personal-info__input">
            <label>
                Email Address:
                <ValidationMessage For="@(() => _personalInfoModel.EmailAddress)" />
            </label>
            <InputText class="personal-info__text-input" @bind-Value="@_personalInfoModel.EmailAddress" placeholder="e.g. stephenking@lorem.com"/>
        </div>
    
        <div class="personal-info__input">
            <label>
                Phone Number:
                <ValidationMessage For="@(() => _personalInfoModel.PhoneNumber)" />
            </label>
            <InputText class="personal-info__text-input" @bind-Value="@_personalInfoModel.PhoneNumber" placeholder="e.g. 234-567-8909"/>
        </div>
    </EditForm>
</div>

@code {
    private PersonalInfoModel _personalInfoModel = new PersonalInfoModel();
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnValidSubmit.InvokeAsync();
    }

    public class PersonalInfoModel
    {
        [Required(ErrorMessage = "This field is required")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "This field is required")]
        public string? EmailAddress { get; set; }

        [Required(ErrorMessage = "This field is required")]
        public string? PhoneNumber { get; set; }
    }
}
