<div class="steps">
    <picture class="steps__background">
        <source media="(min-width:950px)" srcset="images/bg-sidebar-desktop.svg" width="274px"/>
        <img src="/images/bg-sidebar-mobile.svg" alt="bg-image" object-fit="cover" width="100%">
    </picture>
    
    <div class="steps__indicators">
        @foreach (var (stepCount, step) in _steps.Select((data, index) => (index + 1, data)))
        {
            <StepIndicator Step="@stepCount" Text="@step.Step" Selected="@step.Select"/>
        }
    </div>
</div>

@code {
    private readonly (string Step, bool Select)[] _steps = 
        [("YOUR INFO", true), ("SELECT PLAN", false), ("ADD-ONS", false), ("SUMMARY", false)];
}
